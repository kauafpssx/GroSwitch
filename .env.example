# GroSwitch Environment Variables

# Master API Key for authentication (REQUIRED)
MASTER_API_KEY=your-master-api-key-here

# Encryption key for storing Groq API keys (32 chars min, REQUIRED)
MASTER_ENCRYPTION_KEY=your-encryption-key-here-min-32-chars

# Backend port
PORT=3000

# Database connection string
DATABASE_URL=file:./dev.db

# Groq API base URL
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Default model is configured in config.yml at the repo root (not here),
# and can also be changed from the dashboard's Models select.

# Interval (ms) for the background key health monitor
KEY_MONITOR_INTERVAL_MS=60000
